<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_eyebrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONTINUE READING"
        android:textColor="#8A97A6"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08" />

    <TextView
        android:id="@+id/widget_series_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#F4EFE6"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="One Piece" />

    <TextView
        android:id="@+id/widget_chapter_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#C6CDD6"
        android:textSize="14sp"
        tools:text="Chapter 110 of 130" />

    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:max="100"
        android:progressTint="#4DB0A5"
        android:progressBackgroundTint="#333E48" />

</LinearLayout>
